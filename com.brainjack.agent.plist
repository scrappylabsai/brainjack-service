<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brainjack.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>AGENT_DIR_PLACEHOLDER/.venv/bin/python</string>
        <string>AGENT_DIR_PLACEHOLDER/agent.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>AGENT_DIR_PLACEHOLDER</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>AGENT_DIR_PLACEHOLDER/brainjack.log</string>
    <key>StandardErrorPath</key>
    <string>AGENT_DIR_PLACEHOLDER/brainjack.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
