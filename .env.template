# BrainJack Agent — Configuration
# Copy to .env and edit. All values have sane defaults.

# --- Auth ---
# Set a token to require authentication. Leave empty or "off" to disable.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BRAINJACK_TOKEN=

# --- Network ---
BRAINJACK_HOST=0.0.0.0
BRAINJACK_PORT=9898

# --- TLS ---
# Paths to PEM cert and key. Leave empty to disable TLS.
BRAINJACK_TLS_CERT=
BRAINJACK_TLS_KEY=

# --- Reverse proxy mode ---
# Set to "true" if behind nginx/caddy/cloudflare tunnel.
# Skips TLS (proxy handles it), trusts X-Forwarded-For, binds localhost.
BRAINJACK_BEHIND_PROXY=false

# --- Rate limiting ---
# Max commands per window, window size in seconds, burst allowance.
BRAINJACK_RATE_LIMIT=30
BRAINJACK_RATE_WINDOW=10
BRAINJACK_RATE_BURST=5

# --- Audit logging ---
# Path to audit log file. Empty = stdout only (no file).
BRAINJACK_AUDIT_LOG=
# Max bytes per log file before rotation (default 10MB).
BRAINJACK_AUDIT_MAX_BYTES=10485760
# Number of rotated log files to keep.
BRAINJACK_AUDIT_BACKUP_COUNT=5
